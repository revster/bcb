<%- include('../partials/head', { title: 'Reminder Quips' }) %>
<%- include('../partials/nav') %>
<div class="container">
  <div class="page-header">
    <h1>Reminder Quips</h1>
  </div>

  <% if (flash) { %>
    <div class="alert alert-success"><%= flash %></div>
  <% } %>
  <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <p class="text-muted">These quips are sent to members who haven't logged reading progress on the Book of the Month in 7+ days.</p>

  <form method="POST" action="/admin/quips" class="add-quip-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-row">
      <input type="text" name="text" placeholder="Enter a new quip…" class="form-control" required>
      <button type="submit" class="btn">Add Quip</button>
    </div>
  </form>

  <% if (quips.length === 0) { %>
    <p class="text-muted">No quips yet. Add one above.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Text</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% quips.forEach((quip, i) => { %>
          <tr>
            <td class="text-muted"><%= i + 1 %></td>
            <td><%= quip.text %></td>
            <td>
              <div class="actions">
                <form method="POST" action="/admin/quips/<%= quip.id %>/delete">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn-sm btn-danger" data-confirm="Delete this quip?">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <p class="text-muted quip-count"><%= quips.length %> quip<%= quips.length === 1 ? '' : 's' %></p>
  <% } %>
</div>
<script>
  document.querySelectorAll('[data-confirm]').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      if (!confirm(btn.getAttribute('data-confirm'))) e.preventDefault();
    });
  });
</script>
</body>
</html>
