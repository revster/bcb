<%- include('../partials/head', { title: mode === 'create' ? 'Add Log' : 'Edit Log' }) %>
<%- include('../partials/nav') %>
<div class="container container-narrow">
  <div class="page-header">
    <h1><%= mode === 'create' ? 'Add Historical Read' : 'Edit Log' %></h1>
    <a href="/admin/logs" class="btn-link">← Back to logs</a>
  </div>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <% if (mode === 'edit' && book) { %>
    <div class="book-preview">
      <% if (book.image) { %><img src="<%= book.image %>" alt="" class="book-cover"><% } %>
      <div>
        <div class="book-title"><%= book.title %></div>
        <div class="book-author">by <%= book.author %></div>
        <% if (book.pages) { %><div class="book-meta"><%= book.pages %> pages</div><% } %>
      </div>
    </div>
    <div class="book-meta-row">
      <strong>Member:</strong> <%= members.find(m => m.userId === log.userId)?.username || log.userId %>
    </div>
  <% } %>

  <form method="POST" action="<%= mode === 'create' ? '/admin/logs' : '/admin/logs/' + log.id %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <% if (mode === 'create') { %>
      <div class="field-group">
        <label>Goodreads URL <span class="required">*</span></label>
        <div class="input-with-button">
          <input type="url" name="goodreadsUrl" id="goodreadsUrl" required
                 placeholder="https://www.goodreads.com/book/show/..."
                 value="<%= values.goodreadsUrl || '' %>">
          <button type="button" class="btn btn-secondary" onclick="lookupBook()">Lookup</button>
        </div>
        <div id="book-preview" class="book-lookup-preview" style="display:none"></div>
      </div>

      <div class="field">
        <label>Member <span class="required">*</span></label>
        <select name="userId" required>
          <option value="">— select member —</option>
          <% members.forEach(m => { %>
            <option value="<%= m.userId %>" <%= values.userId === m.userId ? 'selected' : '' %>>
              <%= m.username %>
            </option>
          <% }) %>
        </select>
      </div>
    <% } %>

    <div class="field">
      <label>Status <span class="required">*</span></label>
      <select name="status" id="statusSelect" required onchange="onStatusChange()">
        <option value="finished"  <%= (values.status || log?.status || 'finished') === 'finished'  ? 'selected' : '' %>>Finished</option>
        <option value="reading"   <%= (values.status || log?.status) === 'reading'   ? 'selected' : '' %>>Reading</option>
        <option value="abandoned" <%= (values.status || log?.status) === 'abandoned' ? 'selected' : '' %>>Abandoned</option>
      </select>
    </div>

    <div class="field-row">
      <div class="field">
        <label>Started Reading</label>
        <input type="date" name="startedAt"
               value="<%= values.startedAt || (log?.startedAt ? new Date(log.startedAt).toISOString().split('T')[0] : '') %>">
      </div>
      <div class="field" id="finishedAtField">
        <label>Finished Reading</label>
        <input type="date" name="finishedAt"
               value="<%= values.finishedAt || (log?.finishedAt ? new Date(log.finishedAt).toISOString().split('T')[0] : '') %>">
      </div>
    </div>

    <div class="field">
      <label>Rating (1–5, decimals OK)</label>
      <input type="number" name="rating" min="1" max="5" step="0.1"
             placeholder="e.g. 4.5"
             value="<%= values.rating || log?.rating || '' %>">
    </div>

    <div class="field">
      <label>
        <input type="checkbox" name="isBotm" id="isBotm" onchange="onBotmChange()"
               <%= (values.isBotm === 'on' || clubBook) ? 'checked' : '' %>>
        Book of the Month
      </label>
      <% if (mode === 'edit' && clubBook && clubBook.progressMessageId) { %>
        <p class="field-note">
          This book has an active Discord #progress post. Unchecking will not remove the BOTM
          designation (the bot manages it). You can still update the month/year below.
        </p>
      <% } %>
    </div>

    <div id="botmFields" class="field-row" style="<%= (values.isBotm === 'on' || clubBook) ? '' : 'display:none' %>">
      <div class="field">
        <label>Month</label>
        <select name="botmMonth">
          <option value="">— none —</option>
          <% ['January','February','March','April','May','June','July','August','September','October','November','December'].forEach((m, i) => { %>
            <option value="<%= i+1 %>"
              <%= (parseInt(values.botmMonth) === i+1 || clubBook?.month === i+1) ? 'selected' : '' %>>
              <%= m %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="field">
        <label>Year</label>
        <input type="number" name="botmYear" min="2000" max="2100" placeholder="e.g. 2024"
               value="<%= values.botmYear || clubBook?.year || '' %>">
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn">
        <%= mode === 'create' ? 'Add Log' : 'Save Changes' %>
      </button>
      <a href="/admin/logs" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>

<script>
function onStatusChange() {
  const status = document.getElementById('statusSelect').value;
  document.getElementById('finishedAtField').style.display =
    status === 'finished' ? '' : 'none';
}

function onBotmChange() {
  const checked = document.getElementById('isBotm').checked;
  document.getElementById('botmFields').style.display = checked ? '' : 'none';
}

async function lookupBook() {
  const url = document.getElementById('goodreadsUrl').value.trim();
  const preview = document.getElementById('book-preview');
  if (!url) { preview.style.display = 'none'; return; }

  preview.style.display = 'block';
  preview.className = 'book-lookup-preview loading';
  preview.textContent = 'Looking up book…';

  try {
    const res = await fetch('/api/books/scrape?url=' + encodeURIComponent(url));
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Lookup failed');
    preview.className = 'book-lookup-preview success';
    preview.innerHTML = `<strong>${data.title}</strong> by ${data.author}`
      + (data.pages ? ` — ${data.pages} pages` : '')
      + (data.fromDb ? ' <em>(already in database)</em>' : '');
  } catch (err) {
    preview.className = 'book-lookup-preview error';
    preview.textContent = 'Error: ' + err.message;
  }
}

// Set initial state
onStatusChange();
</script>
</body>
</html>
