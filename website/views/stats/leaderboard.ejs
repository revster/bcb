<%- include('../partials/head', { title: 'Leaderboard', appName: "Hermione's Army" }) %>
<%- include('../partials/user-nav') %>

<div class="container">
  <div class="page-header">
    <h1>Leaderboard</h1>
    <span class="section-sub">Book of the Month completions</span>
  </div>

  <div class="filter-bar">
    <form method="GET" action="/leaderboard" id="year-form">
      <select name="year" id="filter-year">
        <option value="">All Time</option>
        <% for (const y of years) { %>
          <option value="<%= y %>"<%= filterYear === y ? ' selected' : '' %>><%= y %></option>
        <% } %>
      </select>
    </form>
    <span class="section-sub"><%= rows.length %> member<%= rows.length !== 1 ? 's' : '' %></span>
  </div>

  <% if (!rows.length) { %>
    <p class="empty-state">No Book of the Month data<%= filterYear ? ' for ' + filterYear : '' %>.</p>
  <% } else { %>

  <div class="table-wrap">
    <table id="lb-table">
      <thead>
        <tr>
          <th style="width:48px">Rank</th>
          <th>Member</th>
          <th>Finished</th>
          <th>Enrolled</th>
          <th>Rate</th>
          <th>Avg Rating</th>
        </tr>
      </thead>
      <tbody>
        <%
        let rank = 1;
        for (let i = 0; i < rows.length; i++) {
          if (i > 0 && rows[i].finished < rows[i-1].finished) rank = i + 1;
          const row = rows[i];
          const medal = rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : '';
        %>
        <tr>
          <td class="rank-cell"><%= medal || rank %></td>
          <td><a href="/u/<%= row.userId %>"><%= row.displayName %></a></td>
          <td><strong><%= row.finished %></strong></td>
          <td><%= row.enrolled %></td>
          <td><%= row.rate %>%</td>
          <td><%= row.avgRating !== null ? row.avgRating.toFixed(1) + ' ★' : '—' %></td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <% } %>
</div>

<script>
document.getElementById('filter-year').addEventListener('change', function () {
  document.getElementById('year-form').submit();
});
</script>

</body>
</html>
